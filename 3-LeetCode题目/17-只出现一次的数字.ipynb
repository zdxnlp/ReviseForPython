   "source": [
    "from typing import List\n",
    "\n",
    "class Solution:\n",
    "    def singleNumber(self, nums: List[int]) -> int:\n",
    "        single_num = nums[0]\n",
    "        for i in range(1, len(nums)):\n",
    "            single_num = single_num ^ nums[i]\n",
    "        return single_num"
   ],
